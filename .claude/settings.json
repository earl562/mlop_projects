{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/earlperry/Desktop/Projects/EP/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/earlperry/Desktop/Projects/EP/.claude/hooks/lint-python.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\"); if [[ \"$FILE\" == *.ts* ]]; then cd /Users/earlperry/Desktop/Projects/EP/plotlot/frontend && npx next lint --file \"${FILE#*/frontend/}\" 2>&1 | tail -5; fi",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/earlperry/Desktop/Projects/EP/plotlot && uv run ruff check src/ 2>&1 | tail -10; echo '---'; uv run pytest tests/unit/ -x -q 2>&1 | tail -15",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
